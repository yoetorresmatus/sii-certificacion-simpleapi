# Copia este archivo como .env y completa tus datos localmente.
# No subas .env a GitHub.

SIMPLEAPI_KEY=tu-api-key-simpleapi
SIMPLEAPI_AMBIENTE=certificacion
# Usa certificacion hasta que el portal SII indique que la empresa esta autorizada.
# Luego cambia explicitamente a produccion y usa solo CAF productivos.
# SIMPLEAPI_AMBIENTE=produccion

SII_RUT_EMPRESA=11111111-1
SII_RUT_FIRMANTE=22222222-2
SII_CERT_FILE=certs/firmante.pfx
SII_CERT_PASS=clave-del-certificado

# Datos de impresion PDF
SII_NUMERO_RESOLUCION=0
SII_FECHA_RESOLUCION=2003-05-16
SII_UNIDAD=SANTIAGO
VENDEDOR=Vendedor
FORMA_PAGO=Credito
CONDICION_VENTA=Credito

# Carpeta privada local, ignorada por Git.
CAF_DIR=caf
OUTPUT_DIR=outputs
